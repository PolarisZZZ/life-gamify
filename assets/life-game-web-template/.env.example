# Life Game Web template configuration
# Copy to .env in your deployed app directory and set strong private values.
HOST=127.0.0.1
PORT=8090
BASE_PATH=/lifegame
LIFE_GAME_FILE=/absolute/path/to/memory/life-game.md
LIFE_GAME_USER=your-username
LIFE_GAME_PASSWORD=change-me-use-a-long-random-password
LIFE_GAME_TOKEN=change-me-use-a-long-random-token
LIFE_GAME_SESSION_SECRET=change-me-use-a-64-char-random-secret
